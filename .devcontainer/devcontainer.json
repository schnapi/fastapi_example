{
  "name": "FastAPI Dev Environment",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "njpwerner.autodocstring",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff"
      ]
    }
  },
  "forwardPorts": [
    8000
  ],
  "remoteUser": "myuser",
  "runArgs": [
    "--network=fastapi_default"
  ],
  "workspaceFolder": "/app"
}